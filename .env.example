# ZIKR — local development environment variables
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# .env is gitignored — never commit real keys.

# ── Supabase ──────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── RevenueCat (In-App Subscriptions) ───────────────────
# Dashboard: https://app.revenuecat.com
# iOS key starts with: appl_
# Android key starts with: goog_
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_ios_api_key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_android_api_key

# ── RevenueCat product / entitlement reference ──────────
# Entitlement ID: premium
# Monthly product: zikr_premium_monthly  ($2.99/month)
# Yearly product:  zikr_premium_yearly   ($19.99/year)
